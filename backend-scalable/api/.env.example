# Scalable API — Environment Variables

PORT=3002
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/vyzora

# Redis connection (used by BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT secret — must match /backend JWT_SECRET if sharing the same DB
JWT_SECRET=change_me_in_production

# Allowed origin for dashboard CORS
FRONTEND_URL=http://localhost:3000

# Used in GitHub OAuth redirect URI
BACKEND_URL=http://localhost:8080

# GitHub OAuth app credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
