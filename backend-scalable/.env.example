# backend-scalable — Root Environment Variables
# Used by docker-compose.yml via ${VAR} substitution.
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/vyzora

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── URLs ──────────────────────────────────────────────────────────────────────
# The public URL that the API is reachable at (behind Nginx on port 8080)
BACKEND_URL=http://localhost:8080

# The frontend dashboard URL
FRONTEND_URL=http://localhost:3000

# ── Worker ────────────────────────────────────────────────────────────────────
# Number of concurrent BullMQ jobs the worker processes (default: 5)
WORKER_CONCURRENCY=5
