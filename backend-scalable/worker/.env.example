# Scalable Worker — Environment Variables

# PostgreSQL connection string (must match the API service)
DATABASE_URL=postgresql://user:password@host:5432/vyzora

# Redis connection (used by BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Number of jobs to process concurrently (default: 5)
WORKER_CONCURRENCY=5

NODE_ENV=production
